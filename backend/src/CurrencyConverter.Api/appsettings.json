{
  "Frankfurter": {
    "BaseUrl": "https://api.frankfurter.app/"
  },
  "Jwt": {
    "Issuer": "CurrencyConverter",
    "Audience": "CurrencyConverter.Clients",
    "SigningKey": "super-secret-signing-key-at-least-32chars",
    "ExpiryMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
